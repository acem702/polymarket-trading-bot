# ── Collector feeds ──────────────────────────────────────────────
BINANCE_WS_URL=wss://data-stream.binance.vision
CHAINLINK_WS_URL=wss://ws-live-data.polymarket.com
GAMMA_URL=https://gamma-api.polymarket.com
CLOB_URL=https://clob.polymarket.com

# Limit what the collector streams to cut bandwidth (comma-separated).
# Leave blank to stream everything. For a BTC-only paper run, set BTC / 5m —
# this drops ~85-90% of traffic (no order-book/price feeds for other markets).
COLLECTOR_ASSETS=
COLLECTOR_TIMEFRAMES=

# ── Shared paths ─────────────────────────────────────────────────
# Linux/macOS default: /tmp/polypulse.sock
# Windows default: \\.\pipe\polypulse (IPC_PATH=/tmp/... is auto-remapped on Windows)
IPC_PATH=/tmp/polypulse.sock
DATA_DIR=./data

# ── Dashboard ────────────────────────────────────────────────────
DASHBOARD_BIND=0.0.0.0:3003
# Shared bearer token required on /api + /ws. Leave blank for local-only use.
# MUST be set before exposing the instance publicly (and matched in the app /
# web UI via #token=...). Generate one: `openssl rand -hex 24`.
DASHBOARD_TOKEN=

# Log level for collector + dashboard (trace|debug|info|warn|error).
# Use warn for long unattended runs to keep log files small.
LOG_LEVEL=info

# ── Strategy defaults ────────────────────────────────────────────
STRATEGY_SHARES=5
DUAL_45C_LIMIT_PRICE=0.45
MOMENTUM_90C_LIMIT_PRICE=0.90
MOMENTUM_90C_WINDOW_SECS=3
MOMENTUM_90C_SIGNAL_TAIL_SECS=180
PTB_DEVIATION_LIMIT_PRICE=0.99
PTB_DEVIATION_SIGNAL_WINDOW_SECS=60

# ── Live trading (Polymarket CLOB) ───────────────────────────────
# Set LIVE_TRADING_ENABLED=true and fill credentials to post real orders.
# Beginners: keep false until you read docs/05-live-trading.md
LIVE_TRADING_ENABLED=false
POLYMARKET_PRIVATE_KEY=
POLYMARKET_PROXY_WALLET=
# 0=EOA, 1=email/Magic proxy, 2=browser proxy (Gnosis Safe), 3=POLY_1271 smart contract wallet
POLYMARKET_SIGNATURE_TYPE=3
POLYMARKET_CHAIN_ID=137

# ── Risk management (safety net) ─────────────────────────────────
# All caps are in USD of order cost (price × shares). Enforced before every
# order in both paper and live mode. Tuned for a small (~$100-150) account.
RISK_MAX_ORDER_USD=5
RISK_MAX_POSITION_PER_MARKET_USD=10
RISK_MAX_OPEN_EXPOSURE_USD=20
RISK_MAX_DAILY_SPEND_USD=25
# Realized-loss stop: halt new orders for the day once losses reach this.
RISK_MAX_DAILY_LOSS_USD=10
RISK_MAX_CONCURRENT_POSITIONS=4
