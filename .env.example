# ── Collector feeds ──────────────────────────────────────────────
BINANCE_WS_URL=wss://data-stream.binance.vision
CHAINLINK_WS_URL=wss://ws-live-data.polymarket.com
GAMMA_URL=https://gamma-api.polymarket.com
CLOB_URL=https://clob.polymarket.com

# ── Shared paths ─────────────────────────────────────────────────
# Linux/macOS default: /tmp/polypulse.sock
# Windows default: \\.\pipe\polypulse (IPC_PATH=/tmp/... is auto-remapped on Windows)
IPC_PATH=/tmp/polypulse.sock
DATA_DIR=./data

# ── Dashboard ────────────────────────────────────────────────────
DASHBOARD_BIND=0.0.0.0:3003

# ── Strategy defaults ────────────────────────────────────────────
STRATEGY_SHARES=5
DUAL_45C_LIMIT_PRICE=0.45
MOMENTUM_90C_LIMIT_PRICE=0.90
MOMENTUM_90C_WINDOW_SECS=3
MOMENTUM_90C_SIGNAL_TAIL_SECS=180
PTB_DEVIATION_LIMIT_PRICE=0.99
PTB_DEVIATION_SIGNAL_WINDOW_SECS=60

# ── Live trading (Polymarket CLOB) ───────────────────────────────
# Set LIVE_TRADING_ENABLED=true and fill credentials to post real orders.
# Beginners: keep false until you read docs/05-live-trading.md
LIVE_TRADING_ENABLED=false
POLYMARKET_PRIVATE_KEY=
POLYMARKET_PROXY_WALLET=
# 0=EOA, 1=email/Magic proxy, 2=browser proxy (Gnosis Safe), 3=POLY_1271 smart contract wallet
POLYMARKET_SIGNATURE_TYPE=3
POLYMARKET_CHAIN_ID=137
